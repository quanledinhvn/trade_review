{
	"name": "app-monorepo",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@9.15.0",
	"engines": {
		"node": "^20.19.0 || >=22.12.0"
	},
	"scripts": {
		"dev": "moon run :dev",
		"dev:api": "moon run api:dev",
		"dev:web": "moon run web:dev",
		"build": "moon run :build",
		"lint": "eslint .",
		"format": "prettier --write .",
		"fix": "eslint --fix . && prettier --write .",
		"typecheck": "moon run :typecheck",
		"clean": "rm -rf node_modules .moon/cache **/node_modules **/dist"
	},
	"devDependencies": {
		"@eslint-react/eslint-plugin": "^5.8.12",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-react-hooks": "^7.1.1",
		"prettier": "^3.8.3",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.60.1"
	}
}
