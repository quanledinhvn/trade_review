{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"module": "CommonJS",
		"moduleResolution": "Node",
		"verbatimModuleSyntax": false,
		"isolatedModules": false,
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"declaration": false,
		"declarationMap": false,
		"sourceMap": true
	}
}
